{
  "name": "terminalright",
  "displayName": "Terminal Right",
  "description": "Open a terminal on the right side of the editor without moving the bottom panel",
  "version": "0.1.1",
  "publisher": "werbenhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/werbenhu/terminalright"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
    
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "terminalright.openInRightPanel",
        "title": "%terminalright.openInRightPanel%",
        "category": "Terminal Right",
        "icon": "$(terminal)"
      }
    ],
    "keybindings": [
      {
        "command": "terminalright.openInRightPanel",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "terminalright",
          "title": "Terminal Right",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "terminalright": [
        {
          "id": "terminalright.panel",
          "name": "Terminal Right"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "terminalright.panel",
        "contents": "[$(terminal) Open Terminal on Right Side](command:terminalright.openInRightPanel)\n\nClick the button above to create a new terminal on the right side of the editor. The bottom panel stays untouched."
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "terminalright.openInRightPanel",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ],
      "view/title": [
        {
          "command": "terminalright.openInRightPanel",
          "when": "view == terminal",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Terminal Right",
    "properties": {
          "terminalright.autoReveal": {
            "type": "boolean",
            "default": true,
            "description": "%terminalright.config.autoReveal%"
          },
          "terminalright.newTerminalEachTime": {
            "type": "boolean",
            "default": true,
            "description": "%terminalright.config.newTerminalEachTime%"
          }
        }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.9.3"
  }
}
